datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Unit {
  id        String     @id @default(cuid())
  number    String     @unique
  status    String     // "available", "held", "leased"
  rent      Float
  bedrooms  Int
  bathrooms Float
  prospects Prospect[]
  tours     Tour[]
}

model Prospect {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String
  status         String   // "new", "contacted", "tour_scheduled", "toured", "application", "leased", "lost"
  notes          String   @default("")
  assignedUnitId String?
  assignedUnit   Unit?    @relation(fields: [assignedUnitId], references: [id], onDelete: SetNull)
  tourDate       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tasks          Task[]
  statusHistory  StatusHistory[]
  tours          Tour[]
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  prospectId  String
  prospect    Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model StatusHistory {
  id         String   @id @default(cuid())
  status     String
  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Tour {
  id            String    @id @default(cuid())
  prospectId    String
  prospect      Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  unitId        String?
  unit          Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)
  scheduledTime DateTime
  status        String    // "scheduled", "canceled", "completed", "no_show"
  outcome       String?   // "no_show", "completed_next_steps", "completed_follow_up", "completed_not_interested"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
