datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Unit {
  id        String     @id @default(cuid())
  number    String     @unique
  status    String     // "available", "held", "leased"
  rent      Float
  bedrooms  Int
  bathrooms Float
  prospects Prospect[]
}

model Prospect {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String
  status         String   // "new", "contacted", "tour_scheduled", "toured", "application", "leased", "lost"
  notes          String   @default("")
  assignedUnitId String?
  assignedUnit   Unit?    @relation(fields: [assignedUnitId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
